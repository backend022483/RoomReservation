@model RoomResertionApp.Models.Reservation
@{
    ViewData["Title"] = "Guest Information";
}

<div class="container mt-5">
    <h1 class="mb-4">Guest Information</h1>

    <div class="card mb-4">
        <div class="card-body">
            <h5 class="card-title">Selected Room</h5>
            <p><strong>@Model.Room.Type - Room @Model.Room.RoomNumber</strong></p>
            <p>@Model.Room.Description</p>
            <p><strong>Price:</strong> $@Model.Room.PricePerNight / night</p>
            <p><strong>Check-in:</strong> @Model.CheckInDate.ToString("dddd, MMMM dd, yyyy")</p>
            <p><strong>Check-out:</strong> @Model.CheckOutDate.ToString("dddd, MMMM dd, yyyy")</p>
            <p><strong>Guests:</strong> @Model.NumberOfGuests</p>
        </div>
    </div>

    <div class="card">
        <div class="card-body">
            <h5 class="card-title mb-4">Enter Your Details</h5>
            <form asp-action="GuestInfo" method="post">
                <input type="hidden" asp-for="RoomId" />
                <input type="hidden" asp-for="CheckInDate" />
                <input type="hidden" asp-for="CheckOutDate" />
                <input type="hidden" asp-for="NumberOfGuests" />
                
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Guest.FirstName" class="form-label">First Name</label>
                        <input asp-for="Guest.FirstName" class="form-control" required />
                        <span asp-validation-for="Guest.FirstName" class="text-danger"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="Guest.LastName" class="form-label">Last Name</label>
                        <input asp-for="Guest.LastName" class="form-control" required />
                        <span asp-validation-for="Guest.LastName" class="text-danger"></span>
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="Guest.Email" class="form-label">Email</label>
                    <input asp-for="Guest.Email" class="form-control" type="email" required />
                    <span asp-validation-for="Guest.Email" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Guest.PhoneNumber" class="form-label">Phone Number</label>
                    <input asp-for="Guest.PhoneNumber" class="form-control" type="tel" required />
                    <span asp-validation-for="Guest.PhoneNumber" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Guest.Address" class="form-label">Address</label>
                    <input asp-for="Guest.Address" class="form-control" />
                    <span asp-validation-for="Guest.Address" class="text-danger"></span>
                </div>

                <div class="d-flex justify-content-between mt-4">
                    <a asp-action="SelectRoom" class="btn btn-secondary">Back to Rooms</a>
                    <button type="submit" class="btn btn-primary">Continue to Confirmation</button>
                </div>
            </form>
        </div>
    </div>
</div>
