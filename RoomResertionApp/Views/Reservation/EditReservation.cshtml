@model RoomResertionApp.Models.Reservation
@{
    ViewData["Title"] = "Edit Reservation";
}

<div class="container mt-5">
    <h1 class="mb-4">Edit Reservation</h1>

    <div class="card mb-4">
        <div class="card-body">
            <h5 class="card-title">Reservation Details</h5>
            <p><strong>Confirmation:</strong> @Model.ConfirmationNumber</p>
            <p><strong>@Model.Room.Type - Room @Model.Room.RoomNumber</strong></p>
            <p>@Model.Room.Description</p>
            <p><strong>Price:</strong> $@Model.Room.PricePerNight / night</p>
        </div>
    </div>

    <div class="card">
        <div class="card-body">
            <h5 class="card-title mb-4">Modify Reservation</h5>
            <form asp-action="EditReservation" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="RoomId" />
                <input type="hidden" asp-for="GuestId" />
                <input type="hidden" asp-for="ConfirmationNumber" />
                <input type="hidden" asp-for="BookingDate" />
                <input type="hidden" asp-for="Status" />
                <input type="hidden" asp-for="TotalPrice" />

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Check-in Date</label>
                        <input asp-for="CheckInDate" class="form-control" type="date" required />
                        <span asp-validation-for="CheckInDate" class="text-danger"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Check-out Date</label>
                        <input asp-for="CheckOutDate" class="form-control" type="date" required />
                        <span asp-validation-for="CheckOutDate" class="text-danger"></span>
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label">Number of Guests</label>
                    <input asp-for="NumberOfGuests" class="form-control" type="number" min="1" max="10" required />
                    <span asp-validation-for="NumberOfGuests" class="text-danger"></span>
                </div>

                <hr class="my-4">
                <h5 class="card-title mb-3">Guest Information</h5>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Guest.FirstName" class="form-label">First Name</label>
                        <input asp-for="Guest.FirstName" class="form-control" required />
                        <span asp-validation-for="Guest.FirstName" class="text-danger"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="Guest.LastName" class="form-label">Last Name</label>
                        <input asp-for="Guest.LastName" class="form-control" required />
                        <span asp-validation-for="Guest.LastName" class="text-danger"></span>
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="Guest.Email" class="form-label">Email</label>
                    <input asp-for="Guest.Email" class="form-control" type="email" required />
                    <span asp-validation-for="Guest.Email" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Guest.PhoneNumber" class="form-label">Phone Number</label>
                    <input asp-for="Guest.PhoneNumber" class="form-control" type="tel" required />
                    <span asp-validation-for="Guest.PhoneNumber" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Guest.Address" class="form-label">Address</label>
                    <input asp-for="Guest.Address" class="form-control" />
                    <span asp-validation-for="Guest.Address" class="text-danger"></span>
                </div>

                <div class="d-flex justify-content-between mt-4">
                    <a asp-action="MyReservations" class="btn btn-secondary">Cancel</a>
                    <button type="submit" class="btn btn-primary">Update Reservation</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
