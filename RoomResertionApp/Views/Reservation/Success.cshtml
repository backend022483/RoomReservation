@model RoomResertionApp.Models.Reservation
@{
    ViewData["Title"] = "Booking Confirmed";
}

<div class="container mt-5">
    <div class="card">
        <div class="card-body text-center">
            <div class="text-success mb-4">
                <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" fill="currentColor" class="bi bi-check-circle-fill" viewBox="0 0 16 16">
                    <path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0zm-3.97-3.03a.75.75 0 0 0-1.08.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-.01-1.05z"/>
                </svg>
            </div>
            
            <h1 class="mb-4">Booking Confirmed!</h1>
            
            <div class="alert alert-success">
                <h3>Confirmation Number: @Model.ConfirmationNumber</h3>
            </div>

            <div class="text-start mt-4">
                <h5 class="mb-3">Reservation Details</h5>
                <table class="table table-bordered">
                    <tr>
                        <td><strong>Room:</strong></td>
                        <td>@Model.Room.Type - Room @Model.Room.RoomNumber</td>
                    </tr>
                    <tr>
                        <td><strong>Guest:</strong></td>
                        <td>@Model.Guest.FirstName @Model.Guest.LastName</td>
                    </tr>
                    <tr>
                        <td><strong>Email:</strong></td>
                        <td>@Model.Guest.Email</td>
                    </tr>
                    <tr>
                        <td><strong>Check-in:</strong></td>
                        <td>@Model.CheckInDate.ToString("dddd, MMMM dd, yyyy")</td>
                    </tr>
                    <tr>
                        <td><strong>Check-out:</strong></td>
                        <td>@Model.CheckOutDate.ToString("dddd, MMMM dd, yyyy")</td>
                    </tr>
                    <tr>
                        <td><strong>Total Price:</strong></td>
                        <td>$@Model.TotalPrice.ToString("F2")</td>
                    </tr>
                    <tr>
                        <td><strong>Status:</strong></td>
                        <td>@Model.Status</td>
                    </tr>
                </table>
            </div>

            <div class="alert alert-info mt-4">
                <p class="mb-0">A confirmation email has been sent to @Model.Guest.Email</p>
            </div>

            <div class="mt-4">
                <a asp-action="SelectRoom" class="btn btn-primary">View Rooms</a>
                <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">Return to Home</a>
            </div>
        </div>
    </div>
</div>
