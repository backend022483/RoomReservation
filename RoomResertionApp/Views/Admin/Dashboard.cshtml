@model dynamic
@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="container mt-5">
    <h1 class="mb-4">Admin Dashboard</h1>

    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card text-white bg-primary">
                <div class="card-body">
                    <h5 class="card-title">Total Users</h5>
                    <h2 class="card-text">@Model.TotalUsers</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-white bg-success">
                <div class="card-body">
                    <h5 class="card-title">Active Users</h5>
                    <h2 class="card-text">@Model.ActiveUsers</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-white bg-warning">
                <div class="card-body">
                    <h5 class="card-title">Inactive Users</h5>
                    <h2 class="card-text">@(Model.TotalUsers - Model.ActiveUsers)</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-white bg-info">
                <div class="card-body">
                    <h5 class="card-title">Administrators</h5>
                    <h2 class="card-text">@Model.UsersByRole["Administrator"]</h2>
                </div>
            </div>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">Users by Role</h5>
                </div>
                <div class="card-body">
                    <ul class="list-group">
                        @foreach (var role in Model.UsersByRole)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                @role.Key
                                <span class="badge bg-primary rounded-pill">@role.Value</span>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">Recent Users</h5>
                </div>
                <div class="card-body">
                    <ul class="list-group">
                        @foreach (var user in Model.RecentUsers)
                        {
                            <li class="list-group-item">
                                <strong>@user.FirstName @user.LastName</strong> (@user.Username)
                                <br />
                                <small class="text-muted">@user.Role - Created @user.CreatedAt.ToString("MMM dd, yyyy")</small>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-body">
                    <a asp-action="CreateAdminAccount" class="btn btn-danger btn-lg">Create Administrator Account</a>
                    <a asp-action="Users" class="btn btn-primary btn-lg">Manage Users</a>
                    <a asp-action="Rooms" class="btn btn-success btn-lg">Manage Rooms</a>
                    <a asp-action="ReservationStatistics" class="btn btn-info btn-lg">Reservation Statistics</a>
                    <a asp-action="LoginActivity" class="btn btn-secondary btn-lg">View Login Activity</a>
                    <a asp-controller="Reservation" asp-action="SelectRoom" class="btn btn-dark btn-lg">View Reservations</a>
                </div>
            </div>
        </div>
    </div>
</div>
