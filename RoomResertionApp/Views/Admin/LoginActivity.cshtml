@model List<RoomResertionApp.Models.LoginActivity>
@{
    ViewData["Title"] = "Login Activity";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Login Activity Log</h1>
        <a asp-action="Dashboard" class="btn btn-secondary">Back to Dashboard</a>
    </div>

    <div class="card">
        <div class="card-body">
            @if (Model == null || !Model.Any())
            {
                <div class="alert alert-info">
                    No login activity recorded yet.
                </div>
            }
            else
            {
                <table class="table table-striped">
                    <thead>
                        <tr>
                            <th>Timestamp</th>
                            <th>Username</th>
                            <th>Status</th>
                            <th>Role</th>
                            <th>IP Address</th>
                            <th>Error Message</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var activity in Model)
                        {
                            <tr>
                                <td>@activity.Timestamp.ToString("yyyy-MM-dd HH:mm:ss")</td>
                                <td>@activity.Username</td>
                                <td>
                                    @if (activity.Success)
                                    {
                                        <span class="badge bg-success">Success</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Failed</span>
                                    }
                                </td>
                                <td>@activity.UserRole ?? "N/A"</td>
                                <td>@activity.IpAddress</td>
                                <td>@activity.ErrorMessage ?? "-"</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
</div>
